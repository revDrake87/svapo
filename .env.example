# Copy this file to .env and fill in your values
# Never commit .env to version control

# MySQL
MYSQL_DATABASE=vapestore
MYSQL_ROOT_PASSWORD=change_me_in_production

# Backend DB credentials (should match MYSQL_ROOT_PASSWORD above)
DB_USER=root
DB_PASSWORD=change_me_in_production

# Upload directory (inside the container — do not change unless you update docker-compose.yml)
UPLOAD_DIR=/app/uploads

# CORS: comma-separated list of allowed frontend origins
# For local Docker: http://localhost
# For production: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost
